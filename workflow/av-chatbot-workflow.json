{
  "name": "AuxoVelari - Chatbot Backend",
  "nodes": [
    {
      "id": "webhook-receive",
      "name": "Webhook Chat",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        250,
        300
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "av-chatbot",
        "responseMode": "lastNode",
        "options": {}
      }
    },
    {
      "id": "format-prompt",
      "name": "Prepare DeepSeek",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const msg = $input.first().json.body.message;\nconst userId = $input.first().json.body.userId || 'anon';\nconst sessionId = $input.first().json.body.sessionId || 'av_' + Date.now();\nconst businessName = $input.first().json.body.businessName || 'Cala Blanca';\nconst history = $input.first().json.body.history || [];\n\nconst systemPrompt = `Eres el asistente virtual de ${businessName}. Responde de forma amable, natural y concisa. Usa la informacion del negocio para responder.\n\nINFORMACION DEL NEGOCIO:\n- Nombre: ${businessName}\n- Horario: Lun-Dom 13:00-16:00 y 19:00-23:30\n- Direccion: Paseo Maritimo 42, Cala Blanca, Ciutadella, Menorca\n- Telefono: +34 971 48 52 10\n- Email: info@calablanca.es\n- Especialidad: mariscos, caldereta de langosta, arroz negro, pulpo a la brasa\n- Precios: 16-42 euros por plato principal, menu degustacion 65 euros\n- Reservas: hasta 30 dias de antelacion, grupos +8 consultar\n- Terraza disponible, vistas al mar, acceso adaptado\n\nPAUTAS:\n- Responde en espanol, tono profesional pero cercano\n- Si el visitante pregunta algo que no sabes, dilo con honestidad y ofrece conectarle con una persona\n- Si el visitante muestra intencion de compra (pregunta precios, disponibilidad, reservas), ofrece amablemente comprobar disponibilidad\n- NO inventes informacion que no tengas`;\n\nconst messages = [{ role: 'system', content: systemPrompt }];\nconst recentHistory = history.slice(-8);\nfor (const h of recentHistory) {\n  messages.push({ role: h.role, content: h.content });\n}\nmessages.push({ role: 'user', content: msg });\n\nconst hasLeadIntent = /reserva|precio|disponib|mesa|cena|comida|para \\d|cu[áa]nto|cuesta|pedir/.test(msg.toLowerCase());\n\nreturn [{\n  json: {\n    userId, sessionId, message: msg, businessName,\n    hasLeadIntent, timestamp: new Date().toISOString(),\n    deepseekPayload: JSON.stringify({\n      model: 'deepseek-chat', messages,\n      temperature: 0.7, max_tokens: 800\n    })\n  }\n}];"
      }
    },
    {
      "id": "deepseek-call",
      "name": "DeepSeek API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        650,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.deepseek.com/v1/chat/completions",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer TU_DEEPSEEK_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $json.deepseekPayload }}",
        "options": {}
      }
    },
    {
      "id": "format-response",
      "name": "Format Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        850,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const data = $input.first().json;\nconst text = data.choices?.[0]?.message?.content || 'Lo siento, hubo un error.';\nconst prepData = $('Prepare DeepSeek').first().json;\n\nreturn [{\n  json: {\n    response: text,\n    sessionId: prepData.sessionId || 'unknown',\n    hasLeadIntent: prepData.hasLeadIntent || false,\n    businessName: prepData.businessName || 'Cala Blanca',\n    userMessage: prepData.message || '',\n    timestamp: prepData.timestamp || ''\n  }\n}];"
      }
    },
    {
      "id": "sheets-crm",
      "name": "Google Sheets CRM",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        1050,
        300
      ],
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "TU_SHEET_ID"
        },
        "sheetName": {
          "__rl": true,
          "mode": "name",
          "value": "Hoja 1"
        },
        "range": "Hoja 1!A:F",
        "columns": {
          "mappingMode": "defineBelow",
          "schema": [
            {
              "id": "timestamp",
              "displayName": "Timestamp",
              "type": "string",
              "defaultMatch": true
            },
            {
              "id": "userId",
              "displayName": "UserID",
              "type": "string"
            },
            {
              "id": "mensaje",
              "displayName": "Mensaje",
              "type": "string"
            },
            {
              "id": "respuesta",
              "displayName": "Respuesta",
              "type": "string"
            },
            {
              "id": "estado",
              "displayName": "Estado",
              "type": "string"
            }
          ],
          "value": {
            "timestamp": "={{ $('Prepare DeepSeek').first().json.timestamp }}",
            "userId": "={{ $('Prepare DeepSeek').first().json.userId }}",
            "mensaje": "={{ $('Prepare DeepSeek').first().json.message }}",
            "respuesta": "={{ $json.response }}",
            "estado": "Completado"
          }
        },
        "options": {}
      }
    },
    {
      "id": "telegram-notify",
      "name": "Telegram Notify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1250,
        400
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/botTU_TELEGRAM_TOKEN/sendMessage",
        "authentication": "none",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            {
              "name": "chat_id",
              "value": "TU_CHAT_ID"
            },
            {
              "name": "text",
              "value": "={{ '🔥 ' + $('Format Response').first().json.businessName + ' | ' + $('Prepare DeepSeek').first().json.message }}"
            }
          ]
        },
        "sendHeaders": false,
        "options": {}
      }
    },
    {
      "id": "output-response",
      "name": "Output Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1450,
        400
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const formatData = $('Format Response').first().json;\nreturn [{ json: { response: formatData.response } }];"
      }
    }
  ],
  "connections": {
    "Webhook Chat": {
      "main": [
        [
          {
            "node": "Prepare DeepSeek",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Prepare DeepSeek": {
      "main": [
        [
          {
            "node": "DeepSeek API",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "DeepSeek API": {
      "main": [
        [
          {
            "node": "Format Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Format Response": {
      "main": [
        [
          {
            "node": "Google Sheets CRM",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google Sheets CRM": {
      "main": [
        [
          {
            "node": "Telegram Notify",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Telegram Notify": {
      "main": [
        [
          {
            "node": "Output Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    {
      "name": "auxovelari"
    },
    {
      "name": "chatbot"
    },
    {
      "name": "mvp"
    }
  ]
}